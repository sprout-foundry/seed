{
  "actions": [
    {
      "id": 1,
      "method": "agent.new",
      "params": {}
    },
    {
      "id": 2,
      "method": "mock.addTool",
      "params": {
        "description": "Get weather",
        "name": "weather",
        "parameters": {
          "properties": {
            "location": {
              "type": "string"
            }
          },
          "type": "object"
        }
      }
    },
    {
      "id": 3,
      "method": "mock.addToolCallResponse",
      "params": {
        "calls": [
          {
            "arguments": {
              "location": "NYC"
            },
            "id": "call_1",
            "name": "weather"
          },
          {
            "arguments": {
              "location": "LA"
            },
            "id": "call_2",
            "name": "weather"
          }
        ]
      }
    },
    {
      "id": 4,
      "method": "mock.addToolResult",
      "params": {
        "content": "NYC: Sunny, 72°F",
        "toolCallId": "call_1"
      }
    },
    {
      "id": 5,
      "method": "mock.addToolResult",
      "params": {
        "content": "LA: Cloudy, 65°F",
        "toolCallId": "call_2"
      }
    },
    {
      "id": 6,
      "method": "mock.addTextResponse",
      "params": {
        "content": "NYC is sunny 72°F, LA is cloudy 65°F."
      }
    },
    {
      "id": 7,
      "method": "agent.run",
      "params": {
        "query": "Weather in NYC and LA?"
      }
    }
  ],
  "assertions": [
    {
      "id": 1,
      "type": "noError"
    },
    {
      "id": 7,
      "type": "noError"
    },
    {
      "id": 7,
      "result": {
        "result": "NYC is sunny 72°F, LA is cloudy 65°F."
      },
      "type": "response"
    },
    {
      "equals": 2,
      "path": "executorCallCount",
      "type": "mock"
    }
  ],
  "description": "Multiple tool calls in one response are all executed",
  "name": "multi_tool_call"
}